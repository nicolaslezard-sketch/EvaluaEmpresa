generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id              String                    @id @default(cuid())
  name            String?
  email           String                    @unique
  emailVerified   DateTime?
  image           String?
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  proTrialUsedAt  DateTime?
  accounts        Account[]
  companies       Company[]
  oneTimeAccesses OneTimeEvaluationAccess[]
  sessions        Session[]
  subscription    Subscription?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  access_token      String?
  expires_at        Int?
  id_token          String?
  refresh_token     String?
  scope             String?
  session_state     String?
  token_type        String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PaymentEvent {
  id         String   @id @default(cuid())
  provider   String
  externalId String
  type       String
  payload    Json
  createdAt  DateTime @default(now())

  @@unique([provider, externalId])
}

model Subscription {
  id                 String             @id @default(cuid())
  plan               SubscriptionPlan   @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  source             SubscriptionSource @default(MANUAL)
  isTrial            Boolean            @default(false)
  trialStartedAt     DateTime?
  trialEndsAt        DateTime?
  currentPeriodStart DateTime?
  currentPeriodEnd   DateTime?
  providerSubscriptionId String?
  providerCustomerId     String?
  userId             String             @unique
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([plan])
  @@index([status])
  @@index([source])
  @@index([isTrial])
}

model Company {
  id           String           @id @default(cuid())
  name         String
  relationType String
  sector       String?
  size         String?
  criticality  CriticalityLevel @default(MEDIUM)
  description  String?
  status       CompanyStatus    @default(ACTIVE)
  ownerId      String
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  alerts       Alert[]
  owner        User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  evaluations  Evaluation[]

  @@index([ownerId])
  @@index([status])
}

model Evaluation {
  id        String           @id @default(cuid())
  companyId String
  status    EvaluationStatus @default(DRAFT)

  /**
   * Versionado del motor
   */
  engineVersion String @default("1.0.0")

  /**
   * Versionado del esquema de formData
   */
  schemaVersion Int @default(2)

  /**
   * Formulario estructurado
   */
  formData Json

  /**
   * Scores determinísticos
   */
  overallScore      Float?
  executiveCategory ExecutiveCategory?
  financialScore    Float?
  commercialScore   Float?
  operationalScore  Float?
  legalScore        Float?
  strategicScore    Float?

  /**
   * Deltas
   */
  deltaOverall     Float?
  deltaFinancial   Float?
  deltaCommercial  Float?
  deltaOperational Float?
  deltaLegal       Float?
  deltaStrategic   Float?

  /**
   * Datos estructurados del reporte/export
   */
  reportData Json?

  /**
   * PDF opcional
   */
  pdfKey  String?
  pdfSize Int?
  pdfMime String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alerts          Alert[]
  company         Company                   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  oneTimeAccesses OneTimeEvaluationAccess[]

  @@index([companyId])
  @@index([status])
  @@index([engineVersion])
  @@index([schemaVersion])
}

model Alert {
  id           String        @id @default(cuid())
  companyId    String
  evaluationId String?
  severity     AlertSeverity
  type         String
  message      String
  createdAt    DateTime      @default(now())
  company      Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  evaluation   Evaluation?   @relation(fields: [evaluationId], references: [id])

  @@index([companyId])
  @@index([severity])
  @@index([evaluationId])
}

model OneTimeEvaluationAccess {
  id           String     @id @default(cuid())
  userId       String
  evaluationId String
  createdAt    DateTime   @default(now())
  evaluation   Evaluation @relation(fields: [evaluationId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, evaluationId])
  @@index([evaluationId])
}

enum SubscriptionPlan {
  FREE
  PRO
  BUSINESS
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
}

enum SubscriptionSource {
  TRIAL
  MP
  LEMON
  MANUAL
}

enum CompanyStatus {
  ACTIVE
  ARCHIVED
  ARCHIVED_BY_PLAN
}

enum EvaluationStatus {
  DRAFT
  FINALIZED
  EXPIRED
}

enum ExecutiveCategory {
  SOLIDO
  ESTABLE
  VULNERABLE
  CRITICO
}

enum CriticalityLevel {
  LOW
  MEDIUM
  HIGH
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}
